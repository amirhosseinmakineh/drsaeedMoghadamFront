# Copy to .env.local for local builds with push notifications enabled.
# Netlify: set the same keys in Site configuration → Environment variables.

API_BASE_URL=https://drsaeedback.drmoghadam.runflare.run/api

# Firebase Web App config (Firebase Console → Project settings → Your apps → Web)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Firebase Cloud Messaging → Web Push certificates → Key pair
FIREBASE_VAPID_KEY=
