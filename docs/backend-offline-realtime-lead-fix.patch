--- /dev/null
+++ b/DentalDashboard.Domain/DomainServices/OfflineLeadBlockingRules.cs
@@ -0,0 +1,24 @@
+using DentalDashboard.Domain.Enums;
+using DentalDashboard.Domain.Models;
+
+namespace DentalDashboard.Domain.DomainServices
+{
+    public static class OfflineLeadBlockingRules
+    {
+        public static bool IsUnreportedOfflineLead(LeadAssignment lead)
+        {
+            if (lead.IsDeleted || lead.AssignmentType != LeadAssignmentType.OfflineQueue)
+                return false;
+
+            if (lead.ReportSubmittedAt.HasValue)
+                return false;
+
+            return lead.LeadAssignmentState is LeadAssignmentState.New or LeadAssignmentState.Assigned;
+        }
+
+        public static bool BlocksRealtimeAssignment(LeadAssignment lead)
+        {
+            return IsUnreportedOfflineLead(lead);
+        }
+    }
+}
