diff --git a/docs/sql/2026-07-08-offline-followup-state-fix.sql b/docs/sql/2026-07-08-offline-followup-state-fix.sql
new file mode 100644
index 0000000..f59137e
--- /dev/null
+++ b/docs/sql/2026-07-08-offline-followup-state-fix.sql
@@ -0,0 +1,43 @@
+-- Fix misclassified offline follow-up leads for consultants 59 and 68.
+-- Run preview first, then apply update.
+
+-- Preview
+SELECT
+    ConsultantProfileId,
+    LeadAssignmentState,
+    CallResult,
+    COUNT(*) AS Cnt
+FROM LeadAssignments
+WHERE IsDeleted = 0
+  AND AssignmentType = 2
+  AND ConsultantProfileId IN (59, 68)
+  AND LeadAssignmentState = 3
+  AND ContactedAt IS NOT NULL
+  AND CallResult IN (3, 4, 5, 6, 7, 8)
+GROUP BY ConsultantProfileId, LeadAssignmentState, CallResult
+ORDER BY ConsultantProfileId, CallResult;
+
+-- Apply: reported non-success offline leads -> Pending (follow-up)
+UPDATE LeadAssignments
+SET LeadAssignmentState = 4
+WHERE IsDeleted = 0
+  AND AssignmentType = 2
+  AND ConsultantProfileId IN (59, 68)
+  AND LeadAssignmentState = 3
+  AND ContactedAt IS NOT NULL
+  AND CallResult IN (3, 4, 5, 6, 7, 8);
+
+-- Verify remaining blockers (should only be New/Assigned without report)
+SELECT
+    ConsultantProfileId,
+    LeadAssignmentState,
+    CallResult,
+    COUNT(*) AS Cnt
+FROM LeadAssignments
+WHERE IsDeleted = 0
+  AND AssignmentType = 2
+  AND ConsultantProfileId IN (59, 68)
+  AND ReportSubmittedAt IS NULL
+  AND LeadAssignmentState IN (1, 2)
+GROUP BY ConsultantProfileId, LeadAssignmentState, CallResult
+ORDER BY ConsultantProfileId, LeadAssignmentState;
