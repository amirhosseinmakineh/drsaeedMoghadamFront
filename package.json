{
  "name": "angular-starter",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "build": "npm run optimize:images && node scripts/generate-firebase-config.mjs && ng build --configuration production",
    "generate:firebase": "node scripts/generate-firebase-config.mjs",
    "start": "http-server dist/demo/browser -p 3000 -a 0.0.0.0",
    "dev": "npm run optimize:images && ng serve --configuration development --host 0.0.0.0",
    "optimize:images": "python3 scripts/optimize-images.py"
  },
  "dependencies": {
    "@angular/animations": "^20.3.0",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.5.0",
    "http-server": "^14.1.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.0",
    "@angular/cli": "^20.3.0",
    "@angular/compiler-cli": "^20.3.0",
    "typescript": "^5.8.2"
  }
}
